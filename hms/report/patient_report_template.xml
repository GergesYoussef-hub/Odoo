<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_patient_card">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div style="border: 3px solid #0066cc; padding: 20px; margin: 20px;">
                            <div style="text-align: center;">
                                <h1 style="color: #cc0000; font-size: 36px; margin-bottom: 20px;">Patient Status Report</h1>
                            </div>
                            
                            <div style="display: table; width: 100%; margin-top: 20px;">
                                <div style="display: table-cell; width: 60%; vertical-align: top;">
                                    <div style="font-size: 16px; line-height: 2;">
                                        <p><strong>Name:</strong> <span t-field="o.first_name"/> <span t-field="o.last_name"/></p>
                                        <p><strong>Age:</strong> <span t-field="o.age"/></p>
                                        <p><strong>Department:</strong> <span t-field="o.department_id.name"/></p>
                                        <p><strong>Doctors:</strong> 
                                            <t t-foreach="o.doctor_ids" t-as="doctor">
                                                <span t-field="doctor.first_name"/> <span t-field="doctor.last_name"/><t t-if="not doctor_last">, </t>
                                            </t>
                                        </p>
                                    </div>
                                </div>
                                
                                <div style="display: table-cell; width: 40%; vertical-align: top; text-align: right;">
                                    <t t-if="o.image">
                                        <img t-att-src="image_data_uri(o.image)" style="max-width: 200px; max-height: 200px; border: 2px solid #333;"/>
                                    </t>
                                    <div style="font-size: 16px; line-height: 2; text-align: left; margin-top: 10px;">
                                        <p><strong>Birth date:</strong> <span t-field="o.birth_date"/></p>
                                        <p><strong>PCR:</strong> <span t-field="o.cr_ratio"/></p>
                                        <p><strong>Blood Type:</strong> <span t-field="o.blood_type"/></p>
                                        <p><strong>Email:</strong> <span t-field="o.email"/></p>
                                    </div>
                                </div>
                            </div>

                            <div style="margin-top: 30px;">
                                <h2 style="color: #cc0000; text-align: center; font-size: 24px;">Log History</h2>
                                <table style="width: 100%; border-collapse: collapse; margin-top: 15px;">
                                    <thead>
                                        <tr style="background-color: #0066cc; color: white;">
                                            <th style="border: 1px solid #ddd; padding: 12px; text-align: left;">User</th>
                                            <th style="border: 1px solid #ddd; padding: 12px; text-align: left;">Date</th>
                                            <th style="border: 1px solid #ddd; padding: 12px; text-align: left;">Info</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="o.log_history_ids" t-as="log">
                                            <tr style="background-color: #e6f0ff;">
                                                <td style="border: 1px solid #ddd; padding: 10px;"><span t-field="log.created_by.name"/></td>
                                                <td style="border: 1px solid #ddd; padding: 10px;"><span t-field="log.date"/></td>
                                                <td style="border: 1px solid #ddd; padding: 10px;"><span t-field="log.description"/></td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
