<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <menuitem id="menu_hms_root" name="Hospital" sequence="10"/>

    <record id="view_patient_tree" model="ir.ui.view">
        <field name="name">hms.patient.list</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <list>
                <field name="first_name"/>
                <field name="last_name"/>
                <field name="email"/>
                <field name="age"/>
                <field name="blood_type"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_patient_form" model="ir.ui.view">
        <field name="name">hms.patient.form</field>
        <field name="model">hms.patient</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                    <button name="print_report" string="Print Report" type="object" class="btn-primary"/>
                </header>
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <group>
                        <group>
                            <field name="first_name"/>
                            <field name="last_name"/>
                            <field name="email"/>
                            <field name="birth_date"/>
                            <field name="age"/>
                            <field name="blood_type"/>
                        </group>
                        <group>
                            <field name="pcr"/>
                            <field name="cr_ratio"/>
                            <field name="address"/>
                        </group>
                    </group>
                    <group>
                        <field name="department_id" domain="[('is_opened', '=', True)]"/>
                        <field name="department_capacity"/>
                        <field name="doctor_ids" widget="many2many_tags" groups="hms.group_hms_manager"/>
                    </group>
                    <notebook>
                        <page string="History">
                            <field name="history"/>
                        </page>
                        <page string="Log History">
                            <field name="log_history_ids">
                                <list>
                                    <field name="created_by"/>
                                    <field name="date"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">hms.patient</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hms_patients" name="Patients" parent="menu_hms_root" action="action_patient" sequence="10"/>
</odoo>
